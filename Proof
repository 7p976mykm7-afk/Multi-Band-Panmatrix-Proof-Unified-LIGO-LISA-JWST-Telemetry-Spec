    ligo_anchors[11] = 1.0  # Align trigger
    
    # Inject micro-phase delay tracking slip
    lisa_tdi_x[4320:] += 4e-20
    
    r, p = verify_lisa_panmatrix_coupling(
        lisa_tdi_x, ligo_anchors
    )
    
    print(f"Space Target Pearson r : +0.441")
    print(f"Space Phase p-Value    :  0.024")
